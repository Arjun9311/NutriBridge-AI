rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(data) {
      return isSignedIn() && data.userId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Case entity
    function isValidCase(data) {
      return data.keys().hasAll(['imageUrl', 'cropType', 'disease', 'confidence', 'recommendation', 'weather', 'location', 'timestamp', 'userId'])
        && data.imageUrl is string && data.imageUrl.size() <= 1024
        && data.cropType is string && data.cropType.size() <= 100
        && data.disease is string && data.disease.size() <= 100
        && data.confidence is number && data.confidence >= 0 && data.confidence <= 1
        && data.recommendation is map
        && data.recommendation.keys().hasAll(['action', 'time', 'reason', 'cost', 'savings', 'risk', 'explanation'])
        && data.weather is map
        && data.location is map
        && data.timestamp is timestamp
        && data.userId == request.auth.uid;
    }

    // Collection: Cases
    match /cases/{caseId} {
      // Users can list and read cases. 
      // For Heatmap, we might allow public read, but for now we restrict to signed in users.
      // Privacy-first: allow reading own data or all data if heatmap is intended to be public.
      // User requested Heatmap, so let's allow public read for shared knowledge.
      allow read: if isSignedIn();
      
      // Only signed in users can create cases, following validation.
      allow create: if isSignedIn() && isValidCase(incoming());
      
      // Cases are immutable after creation - no updates or deletes allowed by farmers.
      allow update, delete: if false;
    }
  }
}
